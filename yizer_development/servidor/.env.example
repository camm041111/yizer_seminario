# Configuración de JWT y admin de desarrollo
JWT_SECRET=una_clave_secreta_de_al_menos_16_caracteres
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
# Opcional en local: si queda vacío, el backend usa automáticamente el Origin del navegador.
CLIENT_URL=

# Mercado Pago Checkout Pro
# Usa credenciales de prueba para sandbox y cambia a las reales en producción.
MERCADO_PAGO_ACCESS_TOKEN=TEST-tu_access_token_aqui
MERCADO_PAGO_CURRENCY=MXN
# Requerido solo para recibir confirmaciones automáticas de Mercado Pago. Debe ser HTTPS público.
# MERCADO_PAGO_WEBHOOK_URL=https://tu-dominio.com/api/pagos/mercadopago/webhook

# Opcional: configuración de base de datos
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=1920
# DB_NAME=yizer_database
